# Copy to .env and adjust. .env is gitignored.

# Storage / runtime paths (inside container)
DB_PATH=/data/jobs.db
WORK_DIR=/work

# Pipeline tuning
FRAME_INTERVAL_SECONDS=5
MAX_FRAMES_TO_LLM=30

# Whisper transcription
WHISPER_MODEL=base
WHISPER_LANGUAGE=de

# LLM: lmstudio | anthropic
LLM_PROVIDER=lmstudio
LLM_READ_TIMEOUT=900
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.2

# LM Studio (in this example, running in another service in the same docker-compose.yml)
LM_STUDIO_URL=http://lmstudio:1234/v1/chat/completions
LM_STUDIO_MODEL=gemma4

# Anthropic (set ANTHROPIC_API_KEY and LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
LLM_ANTHROPIC_MODEL=claude-sonnet-4-6
